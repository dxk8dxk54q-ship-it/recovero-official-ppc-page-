<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Force the correct MIME type so Google doesn't think it's HTML
  AddType text/xml .xml
  AddType text/plain .txt

  # 2. If the file actually exists in the public folder, serve it directly
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # 3. Standard React Router catch-all (only for things that AREN'T real files)
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
